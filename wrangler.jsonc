{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cardlist-admin",
  "main": "dist/worker/index.js",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "dist/client"
  },
  "kv_namespaces": [
    {
      "binding": "CARDLIST_KV",
      "id": "50e3b9a942314331898fa22f656f2102"
    }
  ],
  "vars": {
    "REVALIDATE_URL": "https://weareplave.com/api/revalidate",
    "AWS_S3_BUCKET": "weareplave",
    "AWS_S3_REGION": "ap-northeast-2"
  }
}
